{
  "name": "mda-shift-scheduler",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Monthly shift scheduling and trainee assignment app backed by Netlify Database (Postgres).",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx db/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@netlify/database": "^1.1.0",
    "@netlify/functions": "^4.3.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-rc.4-5d5b77c",
    "nodemailer": "^6.9.7",
    "postgres": "^3.4.9",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/nodemailer": "^8.0.1",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
